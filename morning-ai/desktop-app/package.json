{
  "name": "onework",
  "version": "1.0.0",
  "description": "Votre assistant de bureau intelligent connecté à Microsoft 365",
  "main": "index.js",
  "scripts": {
    "start": "node launch.js",
    "build": "electron-builder --win --x64",
    "build:signed": "electron-builder --win --x64 --publish never"
  },
  "keywords": [
    "microsoft365",
    "productivity",
    "ai",
    "assistant"
  ],
  "author": {
    "name": "OneWork",
    "email": "contact@onework.app",
    "url": "https://onework.app"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alexheno/oneworkk"
  },
  "publish": {
    "provider": "github",
    "owner": "Alexheno",
    "repo": "oneworkk"
  },
  "build": {
    "appId": "com.onework.app",
    "productName": "OneWork",
    "copyright": "Copyright © 2024 OneWork. Tous droits réservés.",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "OneWork-Setup-${version}.exe",
      "publisherName": "OneWork",
      "requestedExecutionLevel": "asInvoker",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false,
      "shortcutName": "OneWork",
      "uninstallDisplayName": "OneWork - Assistant IA Microsoft 365",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeader": "assets/icon.ico",
      "installerSidebar": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "include": "assets/installer.nsh"
    },
    "files": [
      "**/*",
      "!node_modules/electron/**",
      "!node_modules/.cache/**",
      "!dist/**"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.3"
  }
}

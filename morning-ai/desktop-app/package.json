{
  "name": "onework",
  "version": "1.0.0",
  "description": "Votre assistant de bureau intelligent connecté à Microsoft 365",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "keywords": [],
  "author": "OneWork",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alexheno/oneworkk"
  },
  "publish": {
    "provider": "github",
    "owner": "Alexheno",
    "repo": "oneworkk"
  },
  "build": {
    "appId": "com.onework.app",
    "productName": "OneWork",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "OneWork-Setup.exe"
    },
    "nsis": {
      "oneClick": true,
      "shortcutName": "OneWork"
    },
    "files": [
      "**/*",
      "!node_modules/electron/**",
      "!node_modules/.cache/**"
    ]
  },
  "devDependencies": {
    "electron": "^13.6.9",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.3"
  }
}
